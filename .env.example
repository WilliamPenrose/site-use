# site-use environment variables
# Copy this file to .env and fill in your values

# Data directory (default: ~/.site-use/)
# SITE_USE_DATA_DIR=

# Proxy for accessing Twitter (required in China)
# SITE_USE_PROXY=http://127.0.0.1:7890
# SITE_USE_PROXY=socks5://127.0.0.1:1080
# SITE_USE_PROXY_USER=
# SITE_USE_PROXY_PASS=

# WebRTC IP handling policy (default: disable_non_proxied_udp)
# disable_non_proxied_udp  — block all non-proxied UDP; prevents IP leak but breaks WebRTC calls (e.g. Twitter Spaces)
# default_public_interface_only — allow default public interface UDP; Spaces works but STUN may expose IP
# off — no policy set; full WebRTC functionality
# SITE_USE_WEBRTC_POLICY=disable_non_proxied_udp
